server.port=8080

spring.datasource.url=jdbc:mysql://localhost:3306/vehicle_booking?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=YOUR_MYSQL_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format-sql=true
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect

jwt.secret-key=YOUR_BASE64_SECRET_KEY_MIN_32_BYTES
jwt.expiration=900000
jwt.refresh-expiration=604800000

logging.level.org.springframework.security=DEBUG
logging.level.vehicle.booking=DEBUG

springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.enabled=true
springdoc.swagger-ui.operationsSorter=method
springdoc.swagger-ui.tagsSorter=alpha
springdoc.show-actuator=true
spring.flyway.repair-on-migrate=true

management.health.mail.enabled=false

spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=YOUR_EMAIL@gmail.com
spring.mail.password=YOUR_GMAIL_APP_PASSWORD
spring.mail.protocol=smtp
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000

cloudinary.cloud-name=YOUR_CLOUD_NAME
cloudinary.api-key=YOUR_CLOUDINARY_API_KEY
cloudinary.api-secret=YOUR_CLOUDINARY_API_SECRET
cloudinary.folder=${CLOUDINARY_FOLDER:vehicle-booking/cars}

twilio.mode=${TWILIO_MODE:mock}
twilio.account-sid=${TWILIO_ACCOUNT_SID:}
twilio.auth-token=${TWILIO_AUTH_TOKEN:}
twilio.verify-service-sid=${TWILIO_VERIFY_SERVICE_SID:}
twilio.mock-otp=${TWILIO_MOCK_OTP:123456}
# Firebase — chọn 1 trong 2 cách:
# Cách 1: base64 của file JSON (dùng cho env var / Docker / server)
#   Lấy base64: base64 -i firebase-service-account.json | tr -d '\n'
firebase.service-account-json=${FIREBASE_SERVICE_ACCOUNT_JSON:}
# Cách 2: đường dẫn tới file JSON (dùng cho local dev)
firebase.service-account-path=${FIREBASE_SERVICE_ACCOUNT_PATH:classpath:firebase-service-account.json}

# VNPay Sandbox — đăng ký tại: https://sandbox.vnpayment.vn/devsupport/
# Sau khi đăng ký sẽ nhận được TMN Code và Hash Secret qua email
vnpay.tmn-code=${VNPAY_TMN_CODE:YOUR_TMN_CODE}
vnpay.hash-secret=${VNPAY_HASH_SECRET:YOUR_HASH_SECRET}
vnpay.pay-url=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# return-url: mobile webview intercept URL này — host không cần reachable khi test mobile
# Khi test web/Postman thì cần ngrok: ngrok http 8080
vnpay.return-url=${VNPAY_RETURN_URL:http://localhost:8080/api/payments/vnpay/return}
# frontend-url: chỉ dùng cho web redirect — có thể giữ localhost khi test mobile
vnpay.frontend-url=${VNPAY_FRONTEND_URL:http://localhost:5173/my-bookings}

# Goong Maps (https://account.goong.io)
# API Key — dùng cho geocoding / autocomplete / routing
goong.api-key=YOUR_GOONG_API_KEY

# ViettelAI eKYC (https://viettelai.vn)
viettelai.token=YOUR_VIETTELAI_TOKEN

# Local Python eKYC fallback (chạy: cd ekyc-service && docker-compose up)
ekyc.local-service-url=http://localhost:8001
